{
  "name": "payment-approval-erp-landing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3000 --strictPort --config vite.config.js --configLoader runner",
    "build": "tsc --noEmit -p tsconfig.json && vite build --config vite.config.js --configLoader runner",
    "preview": "vite preview --host 127.0.0.1 --config vite.config.js --configLoader runner",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "test:e2e": "node --test tests/e2e/*.test.mjs",
    "test:integration": "tsx --test tests/integration/*.test.ts",
    "release:backend-smoke": "node scripts/verify-backend-production-start.mjs",
    "release:core-smoke": "node scripts/run-core-smoke-check.mjs",
    "release:frontend-artifact": "node scripts/verify-frontend-artifact.mjs",
    "release:manifest": "node scripts/generate-release-manifest.mjs",
    "release:verify-manifest": "node scripts/verify-release-manifest.mjs",
    "release:migration-review": "node scripts/generate-migration-review.mjs",
    "release:verify-migration-review": "node scripts/verify-migration-review.mjs",
    "release:audit-append-only": "node scripts/verify-audit-append-only.mjs",
    "release:migration-check": "node scripts/verify-migrations.mjs",
    "release:mutation-safety": "node scripts/verify-mutation-safety.mjs",
    "release:sensitive-data": "node scripts/verify-sensitive-data-exposure.mjs",
    "release:db-test-evidence-run": "node scripts/generate-db-test-evidence.mjs",
    "release:db-test-evidence": "node scripts/verify-db-test-evidence.mjs",
    "release:performance-capacity": "node scripts/verify-performance-capacity.mjs",
    "release:operational-docs": "node scripts/verify-operational-docs.mjs",
    "release:environment-inventory": "node scripts/verify-production-environment-inventory.mjs",
    "release:environment-separation": "node scripts/verify-environment-separation.mjs",
    "release:staging-smoke-evidence": "node scripts/verify-staging-smoke-evidence.mjs",
    "release:backup-restore-evidence": "node scripts/verify-backup-restore-evidence.mjs",
    "release:data-migration-evidence": "node scripts/verify-data-migration-evidence.mjs",
    "release:role-uat-evidence": "node scripts/verify-role-uat-evidence.mjs",
    "release:production-go-live-evidence": "node scripts/verify-production-go-live-evidence.mjs",
    "release:post-go-live-stabilization-evidence": "node scripts/verify-post-go-live-stabilization-evidence.mjs",
    "release:final-acceptance-evidence": "node scripts/verify-final-acceptance-evidence.mjs",
    "release:go-live-handoff": "node scripts/verify-go-live-handoff.mjs",
    "release:release-note": "node scripts/verify-release-note.mjs",
    "release:go-live-readiness": "node scripts/verify-go-live-readiness.mjs",
    "release:go-live-readiness-report": "node scripts/generate-go-live-readiness-report.mjs",
    "release:submission": "node scripts/generate-release-submission.mjs",
    "release:check": "node scripts/verify-release-env.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0"
  }
}
